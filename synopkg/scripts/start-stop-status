#!/bin/sh

PKG_NAME="runcmd"
INSTALL_DIR="/var/packages/${PKG_NAME}"
BINARY="${INSTALL_DIR}/target/runcmd_linux"
VAR_DIR="${INSTALL_DIR}/var"
PID_FILE="${VAR_DIR}/runcmd.pid"
LOG_FILE="${VAR_DIR}/runcmd.log"

is_running() {
    [ -f "${PID_FILE}" ] || return 1
    # 去除空白，防止空 PID 导致 kill 报错
    PID=$(tr -d '[:space:]' < "${PID_FILE}")
    [ -n "${PID}" ] || return 1
    kill -0 "${PID}" 2>/dev/null
}

case "$1" in
    start)
        if is_running; then
            echo "${PKG_NAME} already running (pid=$(cat ${PID_FILE}))"
            exit 0
        fi
        mkdir -p "${VAR_DIR}"
        # cd 到 var/，runcmd.db 写在此处（runcmd 用户有写权限）
        # binary 已 setuid root，子进程以 root 有效身份运行
        cd "${VAR_DIR}"
        "${BINARY}" >> "${LOG_FILE}" 2>&1 &
        echo $! > "${PID_FILE}"
        sleep 1
        if is_running; then
            echo "${PKG_NAME} started (pid=$(cat ${PID_FILE}))"
            exit 0
        else
            echo "${PKG_NAME} failed to start, see: ${LOG_FILE}"
            exit 1
        fi
        ;;

    stop)
        if is_running; then
            kill "$(tr -d '[:space:]' < ${PID_FILE})" 2>/dev/null
            sleep 1
            rm -f "${PID_FILE}"
            echo "${PKG_NAME} stopped"
        fi
        exit 0
        ;;

    status)
        if is_running; then
            echo "running"
            exit 0
        else
            echo "stopped"
            exit 1
        fi
        ;;

    log)
        echo "${LOG_FILE}"
        ;;

    killall)
        pkill -x runcmd_linux 2>/dev/null || true
        rm -f "${PID_FILE}"
        exit 0
        ;;

    *)
        exit 1
        ;;
esac
