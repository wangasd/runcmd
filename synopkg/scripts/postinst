#!/bin/sh
PKG_DEST="${SYNOPKG_PKGDEST:-/volume1/@appstore/runcmd}"
INSTALL_DIR="/var/packages/runcmd"
VAR_DIR="${INSTALL_DIR}/var"
PKG_USER="runcmd"

chmod +x "${PKG_DEST}/runcmd_linux"

# var/ 归 runcmd 所有（写 pid/log/db）
mkdir -p "${VAR_DIR}"
chown "${PKG_USER}:${PKG_USER}" "${VAR_DIR}"
chmod 750 "${VAR_DIR}"

# wol 工具复制到 var/
cp "${PKG_DEST}/wol" "${VAR_DIR}/wol"
chown "${PKG_USER}:${PKG_USER}" "${VAR_DIR}/wol"
chmod 755 "${VAR_DIR}/wol"

# return/ 目录（文件服务目录，仅首次安装）
RETURN_DIR="${VAR_DIR}/return"
if [ ! -d "${RETURN_DIR}" ]; then
    mkdir -p "${RETURN_DIR}"
    chown "${PKG_USER}:${PKG_USER}" "${RETURN_DIR}"
    chmod 750 "${RETURN_DIR}"
fi

# SSH 密钥对（仅首次安装）
SSH_DIR="${VAR_DIR}/.ssh"
if [ ! -f "${SSH_DIR}/id_rsa" ]; then
    mkdir -p "${SSH_DIR}"
    ssh-keygen -t rsa -b 4096 -N "" -f "${SSH_DIR}/id_rsa" -C "runcmd@synology" >/dev/null 2>&1
    chown -R "${PKG_USER}:${PKG_USER}" "${SSH_DIR}"
    chmod 700 "${SSH_DIR}"
    chmod 600 "${SSH_DIR}/id_rsa"
    chmod 644 "${SSH_DIR}/id_rsa.pub"
fi

exit 0
